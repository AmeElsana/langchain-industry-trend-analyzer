# HuggingFace API Token (get one free at https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Optional: OpenAI API Key (if you prefer OpenAI over HuggingFace)
# OPENAI_API_KEY=sk-your_key_here

# Optional: Reddit API credentials (for richer Reddit data)
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# REDDIT_USER_AGENT=EnQue/1.0

# Optional: NewsAPI key (get one free at https://newsapi.org)
# NEWS_API_KEY=your_key_here
